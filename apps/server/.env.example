# ============================================================
#  RobikServer — server environment (copy to .env and fill in)
#  Do NOT commit the real .env — it holds secrets.
# ============================================================

NODE_ENV=development
HOST=0.0.0.0
PORT=4000

# PostgreSQL connection string.
# URL-encode any special chars in the password (! -> %21, @ -> %40, : -> %3A, etc.)
DATABASE_URL="postgresql://robik:CHANGE_ME@localhost:5432/robikserver?schema=public"

# --- Twitch application (https://dev.twitch.tv/console/apps) ---
TWITCH_CLIENT_ID="your_twitch_client_id"
TWITCH_CLIENT_SECRET="your_twitch_client_secret"
# Must match a redirect URL registered on the Twitch app.
TWITCH_REDIRECT_URI="http://localhost:4000/api/auth/twitch/callback"

APP_BASE_URL="http://localhost:4000"
ADMIN_BASE_URL="http://localhost:5173"

TWITCH_BROADCASTER_SCOPES="user:read:chat channel:read:redemptions moderator:read:followers channel:read:subscriptions bits:read moderator:read:chatters"
TWITCH_BOT_SCOPES="user:read:chat user:write:chat user:bot"

# Local game-engine bridges (leave as-is unless you use them).
UNREAL_WS_HOST="127.0.0.1"
UNREAL_WS_PORT="4101"
UNITY_WS_HOST="127.0.0.1"
UNITY_WS_PORT="4102"

# Where the server persists small runtime files (custom commands, etc.).
STORAGE_DIR="./storage"

# --- Admin panel access control (Twitch login + allowlist) ---
# Comma/space separated Twitch logins allowed into the admin panel (no @).
ADMIN_ALLOWED_LOGINS=your_twitch_login
# HMAC secret for signing admin session cookies. REQUIRED, >= 16 chars.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
ADMIN_SESSION_SECRET=change_me_to_a_long_random_secret
# Admin session lifetime in hours (default 168 = 7 days).
ADMIN_SESSION_TTL_HOURS=168
